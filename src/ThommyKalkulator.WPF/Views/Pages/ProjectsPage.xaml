<UserControl x:Class="ThommyKalkulator.WPF.Views.Pages.ProjectsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1400"
             Background="{DynamicResource WindowBackgroundBrush}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="420" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,20">
            <TextBlock Text="{Binding PageTitle}"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <TextBlock Text="{Binding PageDescription}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1"
                Grid.Column="0"
                Margin="0,0,16,0"
                Padding="16"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,16">
                    <TextBox Width="280"
                             Padding="8,6"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Suche nach Projektnummer oder Positionsbezeichnung" />

                    <Button Content="Aktualisieren"
                            Command="{Binding RefreshCommand}"
                            Padding="12,6"
                            Margin="12,0,0,0"
                            DockPanel.Dock="Right" />
                </DockPanel>

                <ListView Grid.Row="1"
                          x:Name="ProjectListView"
                          ItemsSource="{Binding Projects}"
                          SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                          SelectionMode="Extended"
                          MouseDoubleClick="ProjectListView_OnMouseDoubleClick"
                          BorderThickness="0"
                          Background="Transparent">
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">
                            <GridViewColumn Header="Projekt-Nr." Width="110" DisplayMemberBinding="{Binding ProjectNumber}" />
                            <GridViewColumn Header="Positionsbezeichnung" Width="200" DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="Datum" Width="120" DisplayMemberBinding="{Binding Date}" />
                            <GridViewColumn Header="Maschinen" Width="220" DisplayMemberBinding="{Binding MachinesSummary}" />
                            <GridViewColumn Header="Materialien" Width="220" DisplayMemberBinding="{Binding MaterialsSummary}" />
                            <GridViewColumn Header="Selbstkosten" Width="120" DisplayMemberBinding="{Binding CostPriceText}" />
                            <GridViewColumn Header="Endpreis" Width="120" DisplayMemberBinding="{Binding EndPriceText}" />
                        </GridView>
                    </ListView.View>
                </ListView>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Bearbeiten"
                            Command="{Binding LoadProjectCommand}"
                            Padding="12,8"
                            Margin="0,0,8,0" />

                    <Button Content="Neu berechnen"
                            Command="{Binding RecalculateProjectCommand}"
                            Padding="12,8"
                            Margin="0,0,8,0" />

                    <Button Content="Löschen"
                            Command="{Binding DeleteProjectCommand}"
                            Padding="12,8"
                            Margin="0,0,20,0" />

                    <Button Content="CSV (einzeln)"
                            Click="ExportSingleCsvButton_OnClick"
                            Padding="12,8"
                            Margin="0,0,8,0" />

                    <Button Content="CSV (alle)"
                            Click="ExportAllCsvButton_OnClick"
                            Padding="12,8"
                            Margin="0,0,8,0" />

                    <Button Content="PDF"
                            Click="ExportPdfButton_OnClick"
                            Padding="12,8" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Padding="16"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                VerticalAlignment="Stretch">
            <StackPanel>
                <TextBlock Text="Details"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16" />

                <TextBlock Text="Für den PDF-Export können mehrere Kalkulationen mit Strg oder Umschalt markiert werden."
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16" />

                <TextBox Text="{Binding DetailsText}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         MinHeight="280"
                         BorderThickness="0"
                         Background="Transparent" />

                <Border Margin="0,16,0,0"
                        Padding="12,8"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
