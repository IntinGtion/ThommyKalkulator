<Window x:Class="ThommyKalkulator.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ThommyKalkulator.WPF.ViewModels"
        xmlns:pages="clr-namespace:ThommyKalkulator.WPF.Views.Pages"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Height="900"
        Width="1400"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20,16"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="{Binding AppTitle}"
                       FontSize="24"
                       FontWeight="SemiBold" />
        </Border>

        <TabControl x:Name="MainTabControl"
                    Grid.Row="1"
                    Margin="16"
                    SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="Kalkulation">
                <pages:CalculationPage />
            </TabItem>

            <TabItem Header="Projekte">
                <pages:ProjectsPage />
            </TabItem>

            <TabItem Header="Materialien">
                <pages:MaterialsPage />
            </TabItem>

            <TabItem Header="Einstellungen">
                <pages:SettingsPage />
            </TabItem>

            <TabItem Header="Darstellung">
                <pages:AppearancePage />
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Padding="12,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1,1,1,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource SecondaryTextBrush}" />
        </Border>
    </Grid>
</Window>